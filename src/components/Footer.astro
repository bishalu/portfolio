---
/**
 * Footer — one quiet line on ink (docs/design/DESIGN.md §5.7).
 * Contact lives in CloseSection (#contact); this is just the sign-off.
 */
const currentYear = new Date().getFullYear()
---

<footer class="footer on-ink">
  <div class="footer-inner">
    <p class="label-mono">© {currentYear} Bishal Upadhyaya</p>
    <p class="label-mono footer-right">
      <a href="https://github.com/bishalu" rel="noopener noreferrer" target="_blank">GitHub</a>
      <span aria-hidden="true"> · </span>
      <a href="https://www.linkedin.com/in/bishaluc" rel="noopener noreferrer" target="_blank">LinkedIn</a>
      <span aria-hidden="true"> · </span>
      <a href="mailto:bishal@vibeset.ai">Email</a>
    </p>
  </div>
</footer>

<style lang="scss">
  .footer {
    border-top: 1px solid var(--hairline-on-ink);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-s);
    margin: 0 auto;
    padding: var(--space-m) var(--space-l);
    max-width: 1200px;
  }

  .footer p {
    margin: 0;
  }

  .footer a {
    color: var(--paper-soft);

    &:hover {
      color: var(--marigold);
    }
  }
</style>
