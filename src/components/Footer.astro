---
import { Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
/**
 * Footer Component
 *
 * @description Personal portfolio footer with navigation and social links
 */
const currentYear = new Date().getFullYear()
---

<footer class="glass-footer">
  <!-- Copyright -->
  <section class="copyright py-6 md:py-8">
    <div class="container flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <p>&copy; {currentYear} Bishal Upadhyaya. All rights reserved.</p>
      <p class="built-with">
        Built with <Icon name="lucide:heart" size="1rem" class="heart-icon" aria-label="love" /> and <Link
          href="https://astro.build/">Astro</Link
        >
      </p>
    </div>
  </section>
</footer>

<style lang="scss">
  .glass-footer {
    position: relative;
    z-index: 10;
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.02);
    border-top: 1px solid rgba(255, 255, 255, 0.4);
    background: var(--glass-bg, rgba(255, 255, 255, 0.7));
  }

  :global(.darkmode .glass-footer) {
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.2);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(15, 15, 18, 0.65);
  }

  section {
    border-top: 1px solid var(--border-color-subtle);
  }

  /* Copyright */
  .copyright {
    color: var(--color-warm-gray);
    font-size: 0.875rem;

    a {
      color: var(--color-living-teal);
    }
  }

  .built-with {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .heart-icon {
    animation: pulse 2s ease-in-out infinite;
    color: var(--color-sunset-coral);
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
  }

  @media (max-width: 768px) {
    /* Mobile styles if needed */
  }
</style>
