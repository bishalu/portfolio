---
/**
 * Hero — typographic, signal-led (docs/design/DESIGN.md, MOTION.md).
 * Name in macro display type over ink; a live oscilloscope trace under the
 * name doubles as Balgo's status indicator (idle breathing → excited while
 * thinking). The Balgo console is the page's first interactive moment; on
 * first submit it blooms into a chat surface (WAAPI — the one scene move).
 * Phones get a full-screen sheet instead of the bloom. No animation library.
 */
---

<section class="hero on-ink" id="hero">
  <div class="hero-container">
    <p class="hero-kicker label-mono" id="hero-kicker">AI systems architect · research → production</p>

    <h1 class="hero-name" id="hero-name">
      <span class="name-line"><span class="name-word">Bishal</span></span>
      <span class="name-line"><span class="name-word">Upadhyaya.</span></span>
    </h1>

    <div class="hero-scope" id="hero-scope" aria-hidden="true">
      <canvas id="hero-osc"></canvas>
    </div>

    <div class="hero-split" id="split-layout">
      <div class="hero-left-column" id="hero-left">
        <p class="hero-tagline">
          I build AI systems end-to-end —<br />
          from peer-reviewed research to products people use.<br />
          <strong>Currently: Vibeset.</strong>
        </p>
      </div>

      <div class="hero-right-column">
        <div class="balgo-portal" id="balgo-portal" data-state="collapsed">
          <div class="portal-header" id="portal-header">
            <span class="live-dot" aria-hidden="true"></span>
            <span class="portal-status label-mono">Available for work</span>
          </div>

          <button type="button" class="portal-close" id="portal-close" aria-label="Close chat">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M18 6 6 18M6 6l12 12"></path>
            </svg>
          </button>

          <div class="balgo-chat-history" id="balgo-chat-history" aria-live="polite">
            <!-- Messages appear here -->
          </div>

          <form id="kinetic-balgo-form" class="balgo-form">
            <textarea
              id="kinetic-input"
              class="balgo-input"
              placeholder="What are we building today?"
              rows="1"
              aria-label="Ask Balgo a question"></textarea>
            <button type="submit" class="balgo-send" id="kinetic-send-btn" aria-label="Send message">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </button>
          </form>

          <div class="balgo-starters" id="balgo-starters" aria-label="Suggested questions">
            <button type="button" class="balgo-starter btn" data-prompt="What is Vibeset?">What is Vibeset?</button>
            <button type="button" class="balgo-starter btn" data-prompt="Tell me about the research behind this site.">The research</button>
            <button type="button" class="balgo-starter btn" data-prompt="How do I work with Bishal?">Work with Bishal</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const hero = document.getElementById('hero')
    if (!hero) return

    const rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const isPhone = () => window.matchMedia('(max-width: 767px)').matches
    const d = (x: number) => (rm ? 1 : x)
    const EXPO_OUT = 'cubic-bezier(0.16, 1, 0.3, 1)'
    const EASE_INOUT = 'cubic-bezier(0.65, 0, 0.35, 1)'

    /* ═══════════════════════════════════════════════════════════════════════
       OSCILLOSCOPE — the site's heartbeat. One rAF loop, paused offscreen.
       Idle: quiet breathing line. Thinking: the signal gets excited.
       ═══════════════════════════════════════════════════════════════════════ */
    const canvas = document.getElementById('hero-osc') as HTMLCanvasElement | null
    const scopeBox = document.getElementById('hero-scope') as HTMLElement | null

    let energyTarget = 0.26
    let energy = 0.26

    const scope = (() => {
      if (!canvas || !scopeBox) return { setState: (_: string) => {} }
      const ctx = canvas.getContext('2d')
      if (!ctx) return { setState: (_: string) => {} }

      const dpr = Math.min(window.devicePixelRatio || 1, 2)
      let w = 0
      let h = 0
      let t = 0
      let raf = 0
      let visible = true

      const resize = () => {
        w = scopeBox.clientWidth
        h = scopeBox.clientHeight
        canvas.width = w * dpr
        canvas.height = h * dpr
        canvas.style.width = `${w}px`
        canvas.style.height = `${h}px`
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0)
      }

      const wave = (x: number, time: number, amp: number) => {
        const k = x / w
        // calm at the edges, lively in the middle
        const envelope = 0.25 + 0.75 * Math.sin(Math.PI * k) ** 1.5
        return (
          amp *
          envelope *
          (Math.sin(k * 7 + time * 1.6) * 0.55 +
            Math.sin(k * 17 - time * 2.3) * 0.3 +
            Math.sin(k * 41 + time * 3.7) * 0.15)
        )
      }

      const drawFrame = () => {
        ctx.clearRect(0, 0, w, h)
        const mid = h / 2
        const amp = mid * 0.82 * energy

        const grad = ctx.createLinearGradient(0, 0, w, 0)
        grad.addColorStop(0, '#d64553')
        grad.addColorStop(1, '#efa33b')

        // soft under-glow pass
        ctx.beginPath()
        for (let x = 0; x <= w; x += 3) {
          const y = mid + wave(x, t, amp)
          x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y)
        }
        ctx.strokeStyle = grad
        ctx.globalAlpha = 0.32
        ctx.lineWidth = 8
        ctx.stroke()

        // main line
        ctx.beginPath()
        for (let x = 0; x <= w; x += 2) {
          const y = mid + wave(x, t, amp)
          x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y)
        }
        ctx.globalAlpha = 1
        ctx.lineWidth = 1.8
        ctx.stroke()
      }

      const loop = () => {
        energy += (energyTarget - energy) * 0.04
        t += 0.016 * (0.6 + energy * 2.2)
        drawFrame()
        raf = requestAnimationFrame(loop)
      }

      const start = () => {
        if (!raf && !rm) raf = requestAnimationFrame(loop)
      }
      const stop = () => {
        cancelAnimationFrame(raf)
        raf = 0
      }

      resize()
      window.addEventListener('resize', () => {
        resize()
        if (rm) drawFrame()
      })

      if (rm) {
        // one static frame — complete, just still
        energy = 0.3
        t = 2.2
        drawFrame()
      } else {
        new IntersectionObserver(
          (entries) => {
            visible = entries[0].isIntersecting
            visible && !document.hidden ? start() : stop()
          },
          { threshold: 0 },
        ).observe(scopeBox)
        document.addEventListener('visibilitychange', () => {
          document.hidden || !visible ? stop() : start()
        })
        start()
      }

      return {
        setState: (state: string) => {
          energyTarget = state === 'thinking' ? 0.85 : 0.26
        },
      }
    })()

    /* ═══════════════════════════════════════════════════════════════════════
       ENTRY — begins when the loading screen hands off (bishal:hero-go)
       ═══════════════════════════════════════════════════════════════════════ */
    const kicker = document.getElementById('hero-kicker')!
    const nameWords = hero.querySelectorAll('.hero-name .name-word')
    const scopeEl = document.getElementById('hero-scope')!
    const heroLeft = document.getElementById('hero-left')!
    const balgoPortal = document.getElementById('balgo-portal') as HTMLDivElement

    const playEntry = () => {
      kicker.animate([{ opacity: 0 }, { opacity: 1 }], { duration: d(400), easing: EXPO_OUT, fill: 'both' })
      nameWords.forEach((word, i) => {
        word.animate([{ transform: 'translateY(105%)' }, { transform: 'translateY(0%)' }], {
          duration: d(550),
          delay: d(50 + i * 120),
          easing: EXPO_OUT,
          fill: 'both',
        })
      })
      scopeEl.animate([{ clipPath: 'inset(0 100% 0 0)' }, { clipPath: 'inset(0 0% 0 0)' }], {
        duration: d(600),
        delay: d(300),
        easing: EASE_INOUT,
        fill: 'both',
      })
      ;[heroLeft, balgoPortal].forEach((el, i) => {
        el?.animate([{ transform: 'translateY(24px)', opacity: 0 }, { transform: 'translateY(0)', opacity: 1 }], {
          duration: d(500),
          delay: d(550 + i * 100),
          easing: EXPO_OUT,
          fill: 'both',
        })
      })
    }

    if ((window as any).__introDone) playEntry()
    else document.addEventListener('bishal:hero-go', playEntry, { once: true })

    /* ═══════════════════════════════════════════════════════════════════════
       BALGO CHAT — loading states themed to the pulse (MOTION.md §4)
       ═══════════════════════════════════════════════════════════════════════ */
    const form = document.getElementById('kinetic-balgo-form') as HTMLFormElement | null
    const input = document.getElementById('kinetic-input') as HTMLTextAreaElement | null
    const sendBtn = document.getElementById('kinetic-send-btn') as HTMLButtonElement | null
    const chatHistory = document.getElementById('balgo-chat-history') as HTMLDivElement | null
    const closeBtn = document.getElementById('portal-close') as HTMLButtonElement | null

    if (!form || !input || !sendBtn || !chatHistory || !balgoPortal || !closeBtn) return

    let isSubmitting = false

    input.addEventListener('input', () => {
      input.style.height = 'auto'
      input.style.height = Math.min(input.scrollHeight, 120) + 'px'
    })

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault()
        handleChatSubmit()
      }
    })

    const animDone = (a: Animation) => a.finished.catch(() => {})

    // Backdrop behind the overlay — created once, toggled per open/close.
    // Mounted inside the hero (NOT body): <main>'s view-transition-name makes
    // it a stacking context, so a body-level veil would paint over the portal.
    const backdrop = document.createElement('div')
    backdrop.className = 'balgo-backdrop'
    backdrop.style.display = 'none'
    hero.appendChild(backdrop)

    // Desktop: the console blooms into a fixed overlay pinned below the
    // header — always fully in view, no scrolling (the one scene move).
    const openOverlay = async () => {
      const heroName = document.getElementById('hero-name')!

      // Drop the entry animation's retained transform (fill:both) — a live
      // transform on a fixed, backdrop-painting element causes render smearing
      balgoPortal.getAnimations().forEach((a) => a.cancel())
      balgoPortal.style.opacity = '1'

      heroLeft.animate(
        [{ opacity: 1, transform: 'translateX(0)' }, { opacity: 0, transform: 'translateX(-32px)' }],
        { duration: d(300), easing: EASE_INOUT, fill: 'both' },
      )
      heroName.animate([{ opacity: 1 }, { opacity: 0.1 }], { duration: d(400), easing: EASE_INOUT, fill: 'both' })
      kicker.animate([{ opacity: 1 }, { opacity: 0.2 }], { duration: d(300), easing: EASE_INOUT, fill: 'both' })

      backdrop.style.display = 'block'
      backdrop.animate([{ opacity: 0 }, { opacity: 1 }], { duration: d(300), fill: 'both' })

      // FLIP into fixed viewport coordinates
      const start = balgoPortal.getBoundingClientRect()
      const w = Math.min(800, window.innerWidth * 0.92)
      const h = Math.min(600, window.innerHeight - 128)
      const left = (window.innerWidth - w) / 2
      const top = 88

      balgoPortal.classList.add('expanded', 'overlay')
      chatHistory.style.display = 'flex'
      Object.assign(balgoPortal.style, { left: `${left}px`, top: `${top}px`, width: `${w}px`, height: `${h}px` })

      const fly = balgoPortal.animate(
        [
          { left: `${start.left}px`, top: `${start.top}px`, width: `${start.width}px`, height: `${start.height}px` },
          { left: `${left}px`, top: `${top}px`, width: `${w}px`, height: `${h}px` },
        ],
        { duration: d(700), easing: EXPO_OUT },
      )
      const sweep = chatHistory.animate(
        [
          { clipPath: 'inset(100% 0 0 0)', opacity: 0 },
          { clipPath: 'inset(0% 0 0 0)', opacity: 1 },
        ],
        { duration: d(450), delay: d(350), easing: EXPO_OUT, fill: 'both' },
      )
      await Promise.all([animDone(fly), animDone(sweep)])
    }

    const closeOverlay = async () => {
      const heroName = document.getElementById('hero-name')!
      backdrop.animate([{ opacity: 1 }, { opacity: 0 }], { duration: d(250), fill: 'both' })
      await animDone(
        balgoPortal.animate(
          [
            { opacity: 1, transform: 'scale(1)' },
            { opacity: 0, transform: 'scale(0.97)' },
          ],
          { duration: d(220), easing: 'cubic-bezier(0.45, 0, 0.7, 0.2)' },
        ),
      )
      backdrop.style.display = 'none'
      balgoPortal.classList.remove('expanded', 'overlay')
      balgoPortal.style.left = balgoPortal.style.top = balgoPortal.style.width = balgoPortal.style.height = ''
      chatHistory.style.display = 'none'

      // restore the editorial scene
      heroLeft.style.display = ''
      heroLeft.animate([{ opacity: 0 }, { opacity: 1 }], { duration: d(350), easing: EXPO_OUT, fill: 'both' })
      heroName.animate([{ opacity: 0.1 }, { opacity: 1 }], { duration: d(400), easing: EXPO_OUT, fill: 'both' })
      kicker.animate([{ opacity: 0.2 }, { opacity: 1 }], { duration: d(300), easing: EXPO_OUT, fill: 'both' })
      balgoPortal.animate([{ opacity: 0 }, { opacity: 1 }], { duration: d(300), easing: EXPO_OUT, fill: 'both' })
    }

    // Phone sheet — slides up full-screen instead of blooming
    const openSheet = async () => {
      balgoPortal.classList.add('expanded', 'sheet')
      chatHistory.style.display = 'flex'
      document.body.style.overflow = 'hidden'
      await animDone(
        balgoPortal.animate([{ transform: 'translateY(100%)' }, { transform: 'translateY(0%)' }], {
          duration: d(400),
          easing: EXPO_OUT,
        }),
      )
    }

    const closeSheet = async () => {
      await animDone(
        balgoPortal.animate([{ transform: 'translateY(0%)' }, { transform: 'translateY(100%)' }], {
          duration: d(300),
          easing: 'cubic-bezier(0.45, 0, 0.7, 0.2)',
        }),
      )
      balgoPortal.classList.remove('sheet', 'expanded')
      chatHistory.style.display = 'none'
      document.body.style.overflow = ''
    }

    const closeChat = () => {
      if (balgoPortal.classList.contains('sheet')) void closeSheet()
      else if (balgoPortal.classList.contains('overlay')) void closeOverlay()
    }

    closeBtn.addEventListener('click', closeChat)
    backdrop.addEventListener('click', closeChat)
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeChat()
    })

    const markdownToHtml = (text: string) =>
      text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\*(.*?)\*/g, '<em>$1</em>')

    const smoothScrollChat = () =>
      chatHistory.scrollTo({ top: chatHistory.scrollHeight, behavior: rm ? 'auto' : 'smooth' })

    // Wrap words in spans so replies can arrive as a staggered cascade
    const wrapWords = (el: HTMLElement) => {
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT)
      const nodes: Text[] = []
      while (walker.nextNode()) nodes.push(walker.currentNode as Text)
      nodes.forEach((node) => {
        const parts = node.textContent?.split(/(\s+)/) ?? []
        const frag = document.createDocumentFragment()
        parts.forEach((part) => {
          if (/^\s+$/.test(part)) {
            frag.appendChild(document.createTextNode(part))
          } else if (part) {
            const s = document.createElement('span')
            s.className = 'tw'
            s.textContent = part
            frag.appendChild(s)
          }
        })
        node.parentNode?.replaceChild(frag, node)
      })
    }

    const typeText = async (element: HTMLElement, text: string) => {
      element.innerHTML = markdownToHtml(text)
      if (rm) return
      wrapWords(element)
      const spans = element.querySelectorAll('.tw')
      let last: Animation | null = null
      spans.forEach((s, i) => {
        last = s.animate(
          [
            { opacity: 0, transform: 'translateY(4px)' },
            { opacity: 1, transform: 'translateY(0)' },
          ],
          { duration: 250, delay: Math.min(i * 16, 2400), easing: 'ease-out', fill: 'both' },
        )
      })
      if (last) await animDone(last)
    }

    const appendUserMessage = (text: string) => {
      const wrapper = document.createElement('div')
      wrapper.className = 'msg msg-user'
      const bubble = document.createElement('div')
      bubble.className = 'msg-bubble msg-bubble-user'
      bubble.textContent = text
      wrapper.appendChild(bubble)
      chatHistory.appendChild(wrapper)
      wrapper.animate(
        [
          { opacity: 0, transform: 'translateY(8px)' },
          { opacity: 1, transform: 'translateY(0)' },
        ],
        { duration: d(300), easing: 'ease-out', fill: 'both' },
      )
      smoothScrollChat()
    }

    const appendAILoading = () => {
      const wrapper = document.createElement('div')
      wrapper.className = 'msg msg-ai ai-loading-wrapper'
      const header = document.createElement('div')
      header.className = 'msg-ai-header'
      header.innerHTML = '<span class="msg-ai-name label-mono">Balgo</span>'
      const bubble = document.createElement('div')
      bubble.className = 'msg-bubble msg-bubble-ai msg-bubble-loading'
      bubble.innerHTML =
        '<div class="pulse-line" role="status" aria-label="Balgo is thinking"></div><div class="pulse-caption">Waking the model…</div>'
      wrapper.appendChild(header)
      wrapper.appendChild(bubble)
      chatHistory.appendChild(wrapper)
      wrapper.animate([{ opacity: 0 }, { opacity: 1 }], { duration: d(300), fill: 'both' })
      smoothScrollChat()
      return wrapper
    }

    const replaceAILoadingWithMessage = async (loadingWrapper: HTMLElement, data: any) => {
      const bubble = loadingWrapper.querySelector('.msg-bubble-ai') as HTMLElement
      if (!bubble) return

      bubble.classList.remove('msg-bubble-loading')
      bubble.innerHTML = ''
      const textEl = document.createElement('div')
      textEl.className = 'msg-text'
      bubble.appendChild(textEl)
      await typeText(textEl, data.reply)
      smoothScrollChat()

      if (data.links && data.links.length > 0) {
        const linksEl = document.createElement('div')
        linksEl.className = 'msg-links'
        linksEl.innerHTML = data.links
          .map(
            (link: any) => `
          <a href="${link.href}" class="msg-link smooth-scroll" data-target="${link.href}">
            <span class="msg-link-glyph" aria-hidden="true">↳</span>
            <span>${link.title}</span>
          </a>
        `,
          )
          .join('')
        bubble.appendChild(linksEl)
        linksEl.animate(
          [
            { opacity: 0, transform: 'translateY(8px)' },
            { opacity: 1, transform: 'translateY(0)' },
          ],
          { duration: d(350), easing: 'ease-out', fill: 'both' },
        )

        linksEl.querySelectorAll('.msg-link.smooth-scroll').forEach((anchor) => {
          anchor.addEventListener('click', (e) => {
            const targetId = anchor.getAttribute('data-target')
            if (targetId && targetId.startsWith('#')) {
              e.preventDefault()
              let scrollTargetId = targetId
              if (targetId.startsWith('#vibeset-')) scrollTargetId = '#vibeset'
              else if (targetId.startsWith('#paper-')) scrollTargetId = targetId
              const targetElement = document.querySelector(scrollTargetId)
              if (targetElement) {
                if (balgoPortal.classList.contains('sheet')) void closeSheet()
                targetElement.scrollIntoView({ behavior: rm ? 'auto' : 'smooth' })
                history.pushState(null, '', targetId)
              }
            }
          })
        })

        smoothScrollChat()
      }

      loadingWrapper.classList.remove('ai-loading-wrapper')
    }

    const handleChatSubmit = async () => {
      if (isSubmitting) return

      const idea = input.value.trim()
      if (!idea) return

      isSubmitting = true
      sendBtn.disabled = true
      scope.setState('thinking')

      try {
        if (!balgoPortal.classList.contains('expanded')) {
          await (isPhone() ? openSheet() : openOverlay())
        }

        input.value = ''
        input.style.height = 'auto'

        appendUserMessage(idea)
        const loadingEl = appendAILoading()

        const controller = new AbortController()
        const timeoutId = setTimeout(() => controller.abort(), 10000)

        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: idea }),
          signal: controller.signal,
        })
        clearTimeout(timeoutId)

        const rawData = await res.json()
        let data = { reply: "Let's connect directly.", links: [] as any[] }
        try {
          if (rawData.reply) {
            if (rawData.links !== undefined) {
              data = { ...rawData }
            } else {
              try {
                const parsed = JSON.parse(rawData.reply)
                if (parsed.reply) data.reply = parsed.reply
                if (parsed.links) data.links = parsed.links
              } catch {
                data.reply = rawData.reply
              }
            }
          }
        } catch {}
        await replaceAILoadingWithMessage(loadingEl, data)
      } catch (e: any) {
        let errorMsg = 'Balgo is unreachable right now — email **bishal@vibeset.ai** instead.'
        if (e.name === 'AbortError') {
          errorMsg = 'That took too long. Try again, or email **bishal@vibeset.ai**.'
        }

        const els = chatHistory.querySelectorAll('.ai-loading-wrapper')
        const errorEl = els[els.length - 1] as HTMLElement
        if (errorEl) {
          await replaceAILoadingWithMessage(errorEl, { reply: errorMsg, links: [] })
        }
      } finally {
        isSubmitting = false
        sendBtn.disabled = false
        scope.setState('idle')
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault()
      handleChatSubmit()
    })

    // One-tap starters — the first success should cost one click (DESIGN.md §6)
    const starters = document.getElementById('balgo-starters')
    starters?.querySelectorAll<HTMLButtonElement>('.balgo-starter').forEach((chip) => {
      chip.addEventListener('click', () => {
        input.value = chip.dataset.prompt ?? chip.textContent ?? ''
        starters.remove()
        handleChatSubmit()
      })
    })
  })
</script>

<style lang="scss">
  .hero {
    display: flex;
    position: relative;
    align-items: stretch;
    width: 100%;
    min-height: 100svh;
    overflow: hidden;
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    margin: 0 auto;
    padding: clamp(5.5rem, 12vh, 8rem) var(--space-l) clamp(2rem, 5vh, 3.5rem);
    width: 100%;
    max-width: 1240px;
  }

  .hero-kicker {
    opacity: 0;
    margin: 0 0 var(--space-s);
  }

  .hero-name {
    margin: 0;
    color: var(--paper);
    font-weight: 600;
    font-size: clamp(3.2rem, 11.5vw, 8.5rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    font-family: var(--font-display);

    .name-line {
      display: block;
      overflow: hidden;
    }

    .name-word {
      display: inline-block;
      transform: translateY(105%);
      will-change: transform;
    }
  }

  .hero-scope {
    margin: clamp(1.25rem, 3vh, 2.5rem) 0;
    width: 100%;
    height: clamp(72px, 12vh, 150px);
    clip-path: inset(0 100% 0 0);

    canvas {
      display: block;
      width: 100%;
      height: 100%;
    }
  }

  /* reduced motion / no-JS: everything visible without the entrance */
  @media (prefers-reduced-motion: reduce) {
    .hero-scope {
      clip-path: none;
    }
    .hero-name .name-word {
      transform: none;
    }
    .hero-kicker,
    .hero-left-column,
    .balgo-portal {
      opacity: 1;
    }
  }
