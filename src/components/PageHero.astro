---
/**
 * PageHero Component
 *
 * A unified, magical hero for all pages.
 * Simple. Bold. Non-corporate.
 *
 * Features:
 * - Animated gradient blobs (respects prefers-reduced-motion)
 * - Configurable size and accent colors
 * - Optional slot for interactive content
 */

interface Props {
  /** Big, bold page title */
  title: string
  /** One-liner description */
  subtitle?: string
  /** Small label above title (e.g., "VibeSet") */
  eyebrow?: string
  /** Height variant */
  size?: 'full' | 'medium' | 'compact'
  /** Blob color theme */
  accent?: 'teal' | 'coral' | 'purple' | 'mixed'
}

const { title, subtitle, eyebrow, size = 'medium', accent = 'teal' } = Astro.props

// Size classes
const sizeClasses = {
  full: 'hero--full',
  medium: 'hero--medium',
  compact: 'hero--compact',
}

// Accent classes for blob colors
const accentClasses = {
  teal: 'hero--accent-teal',
  coral: 'hero--accent-coral',
  purple: 'hero--accent-purple',
  mixed: 'hero--accent-mixed',
}
---

<section class:list={['page-hero', sizeClasses[size], accentClasses[accent]]}>
  <div class="container">
    <div class="hero-content animate-in fade-in slide-in-from-bottom-4 duration-700">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h1 class="hero-title">{title}</h1>
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}

      <!-- Optional slot for interactive content -->
      <slot />
    </div>
  </div>

  <!-- Ambient gradient blobs -->
  <div class="hero-blobs" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>
</section>

<style lang="scss">
  .page-hero {
    display: flex;
    position: relative;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    text-align: center;

    // Size variants
    &.hero--full {
      padding: var(--space-2xl) 0;
      min-height: 100vh;
    }

    &.hero--medium {
      padding: var(--space-2xl) 0 var(--space-xl);
      min-height: 45vh;
    }

    &.hero--compact {
      padding: var(--space-xl) 0;
      min-height: 30vh;
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    margin: 0 auto;
    width: 100%;
    max-width: 700px;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: var(--space-s);
    color: var(--color-living-teal);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero-title {
    margin: 0 0 var(--space-m);
    color: var(--foreground-color);
    font-weight: 800;
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1.05;
    font-family: var(--font-heading);
    letter-spacing: -0.03em;
  }

  .hero-subtitle {
    margin: 0 auto;
    max-width: 550px;
    color: var(--color-warm-gray);
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.6;

    :global(strong) {
      color: var(--foreground-color);
    }
  }

  // Ambient blobs
  .hero-blobs {
    position: absolute;
    z-index: 0;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .blob {
    position: absolute;
    opacity: 0.2;
    filter: blur(90px);
    border-radius: 50%;
  }

  .blob-1 {
    top: -120px;
    right: -80px;
    width: 350px;
    height: 350px;
  }

  .blob-2 {
    bottom: -80px;
    left: 10%;
    width: 280px;
    height: 280px;
  }

  .blob-3 {
    top: 40%;
    left: -60px;
    width: 200px;
    height: 200px;
  }

  // Accent color themes
  .hero--accent-teal {
    .eyebrow {
      color: var(--color-living-teal);
    }
    .blob-1 {
      background: var(--color-living-teal);
    }
    .blob-2 {
      opacity: 0.15;
      background: var(--color-moss-green);
    }
    .blob-3 {
      opacity: 0.12;
      background: var(--color-sunset-coral);
    }
  }

  .hero--accent-coral {
    .eyebrow {
      color: var(--color-sunset-coral);
    }
    .blob-1 {
      background: var(--color-sunset-coral);
    }
    .blob-2 {
      opacity: 0.15;
      background: var(--color-living-teal);
    }
    .blob-3 {
      opacity: 0.12;
      background: #9b59b6;
    }
  }

  .hero--accent-purple {
    .eyebrow {
      color: #9b59b6;
    }
    .blob-1 {
      background: #9b59b6;
    }
    .blob-2 {
      opacity: 0.15;
      background: var(--color-living-teal);
    }
    .blob-3 {
      opacity: 0.12;
      background: var(--color-sunset-coral);
    }
  }

  .hero--accent-mixed {
    .eyebrow {
      color: var(--color-living-teal);
    }
    .blob-1 {
      background: var(--color-living-teal);
    }
    .blob-2 {
      opacity: 0.18;
      background: var(--color-sunset-coral);
    }
    .blob-3 {
      opacity: 0.15;
      background: #9b59b6;
    }
  }

  // Blob animations - respects prefers-reduced-motion
  @media (prefers-reduced-motion: no-preference) {
    .blob {
      animation: blob-morph 14s ease-in-out infinite;
    }
    .blob-2 {
      animation-delay: -5s;
    }
    .blob-3 {
      animation-delay: -10s;
    }

    @keyframes blob-morph {
      0%,
      100% {
        transform: translate(0, 0) scale(1);
        border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
      }
      33% {
        transform: translate(8px, -8px) scale(1.03);
        border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
      }
      66% {
        transform: translate(-8px, 8px) scale(0.97);
        border-radius: 50% 60% 30% 60% / 30% 60% 70% 40%;
      }
    }
  }

  // Responsive adjustments
  @media (max-width: 768px) {
    .page-hero {
      &.hero--medium {
        padding: var(--space-xl) 0;
        min-height: auto;
      }

      &.hero--compact {
        padding: var(--space-l) 0;
        min-height: auto;
      }
    }

    .blob-1 {
      width: 250px;
      height: 250px;
    }

    .blob-2 {
      width: 180px;
      height: 180px;
    }

    .blob-3 {
      width: 140px;
      height: 140px;
    }
  }
</style>
