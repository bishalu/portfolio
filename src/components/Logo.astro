---
import { Link } from 'accessible-astro-components'

/**
 * Logo Component - Bishal Upadhyaya
 */
---

<a href="#hero" class="logo-link">
  <span class="logo-text">bishal<span>.ai</span></span>
</a>

<style>
  .logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: transform 0.2s ease;

    &:hover {
      transform: scale(1.02);
      text-decoration: none;
    }
  }

  .logo-text {
    font-weight: 700;
    font-size: 1.5rem;
    font-family: var(--font-display);
    color: var(--paper);
    letter-spacing: -0.03em;
    line-height: 1;
    display: flex;
    align-items: baseline;
    text-transform: none;

    span {
      color: var(--marigold);
    }
  }

  // Mobile optimization
  @media (max-width: 768px) {
    .logo-text {
      font-size: 1.25rem;
    }
  }
</style>
