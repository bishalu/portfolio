---
/**
 * VibesetSwitchboardWrapper — Astro wrapper for React Switchboard component
 * Aggregates 7 studio modules into 3 product-facing cards.
 */
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import VibesetSwitchboard, { type ProductConsoleItem, type ProductStudioId } from './VibesetSwitchboard'

interface Props {
  studios: CollectionEntry<'studios'>[]
}

const { studios: studiosProp } = Astro.props as Partial<Props>
const studios = (studiosProp ?? (await getCollection('studios'))).sort((a, b) => a.data.order - b.data.order)

const productMeta: Record<
  ProductStudioId,
  Pick<ProductConsoleItem, 'name' | 'tagline' | 'description' | 'accent' | 'id' | 'media'>
> = {
  'curation-engine': {
    id: 'curation-engine',
    name: 'Vibeset Curation',
    tagline: 'The intelligence layer for discovery and set construction',
    description:
      'Combines live discovery, deep catalog search, sequence reasoning, and extension logic to generate coherent setlists that stay true to your intended energy curve.',
    accent: '#5fb3a1',
    media: {
      type: 'video',
      src: '/videos/vibeset-product-demo.mp4',
      alt: 'Vibeset curation engine demo',
    },
  },
  cue: {
    id: 'cue',
    name: 'Vibeset Cue',
    tagline: 'Visual context into soundtrack decisions',
    description:
      'Translates visual mood and edit rhythm into music choices, powering cue-aware matching for videos, scenes, and aesthetic-driven requests.',
    accent: '#9b59b6',
    media: undefined,
  },
  choon: {
    id: 'choon',
    name: 'Vibeset Choon',
    tagline: 'Custom audio fingerprinting for your catalog',
    description:
      'Learns your audio domain to identify tracks, stems, and sampled motifs with high precision, even where generic fingerprinting APIs fail.',
    accent: '#00ced1',
    media: {
      type: 'article',
      href: 'https://www.vibeset.ai/blog/vibeset-choon-protect-your-musical-assets',
      badge: 'Featured Article',
      headline: 'Protect Your Musical Assets with Vibeset Choon',
      excerpt:
        'A closer look at how Choon fingerprints tracks, stems, and motifs to protect catalogs when generic audio matching falls short.',
      ctaLabel: 'Read article',
    },
  },
}

const productOrder: ProductStudioId[] = ['curation-engine', 'cue', 'choon']

const studioIdOrderByProduct: Record<ProductStudioId, CollectionEntry<'studios'>['id'][]> = {
  'curation-engine': ['live-search', 'db-search', 'setlist-editor', 'set-extender', 'logic-flow'],
  cue: ['optic-to-audio', 'video-sync'],
  choon: ['audio-fingerprint'],
}

const studioById = new Map(studios.map((studio) => [studio.id, studio] as const))

const grouped: Record<ProductStudioId, CollectionEntry<'studios'>[]> = {
  'curation-engine': studioIdOrderByProduct['curation-engine']
    .map((studioId) => studioById.get(studioId))
    .filter((studio): studio is CollectionEntry<'studios'> => Boolean(studio)),
  cue: studioIdOrderByProduct.cue
    .map((studioId) => studioById.get(studioId))
    .filter((studio): studio is CollectionEntry<'studios'> => Boolean(studio)),
  choon: studioIdOrderByProduct.choon
    .map((studioId) => studioById.get(studioId))
    .filter((studio): studio is CollectionEntry<'studios'> => Boolean(studio)),
}

const dedupe = (items: string[]) => [...new Set(items)]

const buildStudioModules = (
  productId: ProductStudioId,
  members: CollectionEntry<'studios'>[],
): ProductConsoleItem['studioModules'] => {
  if (productId !== 'curation-engine') {
    return members.map((studio) => ({
      id: studio.id,
      name: studio.data.name,
      href: `/vibeset/studios/${studio.id}/`,
    }))
  }

  const byId = new Map(members.map((studio) => [studio.id, studio] as const))
  const curationModules = [
    { id: 'ai-dj', name: 'AI DJ', sourceId: 'live-search' },
    { id: 'editor', name: 'Editor', sourceId: 'setlist-editor' },
    { id: 'setlist-extender', name: 'Setlist Extender', sourceId: 'set-extender' },
    { id: 'setlist-reasoning', name: 'Setlist Reasoning', sourceId: 'logic-flow' },
  ] as const

  return curationModules
    .map((module): { id: string; name: string; href: string } | null => {
      const source = byId.get(module.sourceId)
      if (!source) return null
      return {
        id: module.id,
        name: module.name,
        href: `/vibeset/studios/${source.id}/`,
      }
    })
    .filter((module): module is { id: string; name: string; href: string } => Boolean(module))
}

const productData: ProductConsoleItem[] = productOrder.map((productId) => {
  const members = grouped[productId]

  return {
    ...productMeta[productId],
    capabilities: dedupe(members.flatMap((studio) => studio.data.features)).slice(0, 6),
    techStack: dedupe(members.flatMap((studio) => studio.data.techStack)),
    sources: members.map((studio) => studio.id),
    studioModules: buildStudioModules(productId, members),
    icon: members[0]?.data.icon,
  }
})
---

<div class="switchboard-wrapper" id="vibeset">
  <div class="glass-container">
    <VibesetSwitchboard client:idle products={productData} />
  </div>
</div>

<style lang="scss">
  :root {
    --vibeset-acid-jazz: #6938ef;
    --vibeset-valence: #1ae8ce;
    --vibeset-dance: #d717e7;
    --vibeset-hard: #1e2330;
    --vibeset-hard-700: #141720;
    --vibeset-off-white: #fdf5e3;
    --vibeset-gradient-primary: linear-gradient(135deg, #6938ef, #d717e7);
  }

  .switchboard-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem 1rem;
    width: 100%;
    min-height: 100dvh;
    scroll-snap-align: start;
  }

  .glass-container {
    display: flex;
    position: relative;
    flex-direction: column;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-glass, 24px);
    background: linear-gradient(135deg, rgba(20, 23, 32, 0.95), rgba(30, 35, 48, 0.9));
    width: 100%;
    max-width: 1200px;
    min-height: 78vh;
    max-height: min(900px, 90vh);
    overflow: hidden;

    &::before {
      position: absolute;
      opacity: 0.6;
      -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      mask-composite: exclude;
      -webkit-mask-composite: xor;
      inset: -1px;
      border-radius: inherit;
      background: linear-gradient(135deg, rgba(105, 56, 239, 0.4), rgba(215, 23, 231, 0.3), rgba(26, 232, 206, 0.2));
      padding: 1px;
      pointer-events: none;
      content: '';
    }
  }

  :global(.vibeset-switchboard) {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    color: var(--vibeset-off-white);
  }

  :global(.switchboard-cover) {
    display: flex;
    position: relative;
    flex: 1;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    text-align: center;
  }

  :global(.cover-glow) {
    position: absolute;
    opacity: 0.5;
    filter: blur(80px);
    inset: -20%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(105, 56, 239, 0.3) 0%, transparent 70%);
    pointer-events: none;
  }

  :global(.cover-content) {
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
  }

  :global(.retina-scan-container) {
    margin-bottom: 1.5rem;
    width: 72px;
    height: 72px;
  }

  :global(.retina-scan-ring) {
    transform: rotate(-90deg);
    width: 100%;
    height: 100%;
  }

  :global(.ring-track) {
    fill: none;
    stroke: rgba(255, 255, 255, 0.12);
    stroke-width: 4;
  }

  :global(.ring-indicator) {
    fill: none;
    stroke: var(--vibeset-valence);
    stroke-linecap: round;
    stroke-width: 4;
  }

  :global(.cover-title) {
    margin-bottom: 0.5rem;
    background: var(--vibeset-gradient-primary);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 800;
    font-size: clamp(2.1rem, 4vw, 3rem);
  }

  :global(.cover-tagline) {
    color: rgba(253, 245, 227, 0.7);
    font-size: 1rem;
  }

  :global(.switchboard-interface) {
    display: flex;
    flex-direction: column;
    padding-top: 1.25rem;
    height: 100%;
    overflow: hidden;
  }

  :global(.tab-bar-container) {
    display: flex;
    position: relative;
    justify-content: center;
    margin-bottom: 2rem;
    padding: 0 1rem;
    width: 100%;
  }

  :global(.studio-tab-bar) {
    display: flex;
    position: relative;
    gap: 0.5rem;
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(30, 35, 48, 0.4);
    padding: 0.35rem;
    width: 100%;
    max-width: 680px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;

    &::-webkit-scrollbar {
      display: none;
    }
  }

  :global(.studio-tab) {
    display: flex;
    position: relative;
    flex: 1;
    justify-content: center;
    align-items: center;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
    cursor: pointer;
    border: 1px solid transparent;
    border-radius: 999px;
    background: transparent;
    padding: 0.6rem 1rem;
    min-width: 110px;
    overflow: hidden;
    scroll-snap-align: center;
    text-align: center;

    &:hover {
      background: rgba(255, 255, 255, 0.04);
    }

    &:focus-visible {
      outline: 2px solid var(--vibeset-valence);
      outline-offset: 2px;
    }

    &.selected {
      border-color: rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.08);
    }
  }

  :global(.tab-content) {
    display: flex;
    position: relative;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
  }

  :global(.tab-icon) {
    opacity: 0.9;
    width: 20px;
    height: 20px;
    object-fit: contain;
  }

  :global(.tab-name) {
    transition: color 0.2s ease;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 600;
    font-size: 0.88rem;
    line-height: 1;
    white-space: nowrap;
  }

  :global(.studio-tab.selected .tab-name) {
    color: #fff;
    text-shadow: 0 0 12px rgba(255, 255, 255, 0.4);
  }

  :global(.tab-indicator) {
    position: absolute;
    bottom: -1px;
    left: 20%;
    z-index: 3;
    border-radius: 999px;
    width: 60%;
    height: 2px;
  }

  :global(.tab-glow-bg) {
    position: absolute;
    opacity: 0.6;
    z-index: 1;
    inset: 0;
    pointer-events: none;
  }

  :global(.console-display) {
    display: flex;
    flex: 1;
    flex-direction: column;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(20, 23, 32, 0.62);
    overflow: hidden;
  }

  /* Desktop grid wrapper — always shown on desktop, hidden on mobile */
  :global(.desktop-grid-layout) {
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  /* Mobile screen deck — hidden on desktop, shown on mobile */
  :global(.mobile-screen-deck) {
    display: none;
  }

  :global(.console-content) {
    display: flex;
    flex-direction: column;
    padding: 1.75rem 2.5rem 2rem;
    height: 100%;
    overflow-y: auto;
  }

  /* ── Option 1: Apple Feature Flow (Desktop) ── */
  :global(.apple-feature-layout) {
    display: grid;
    grid-template-columns: 35% 1fr;
    gap: 1.5rem;
    width: 100%;
  }

  :global(.feature-col-left) {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.feature-col-right) {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.hud-quadrant) {
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.12);
    padding: 1rem;
    min-inline-size: 0;
  }

  :global(.hud-quadrant legend) {
    padding: 0 0.5rem;
    color: rgba(253, 245, 227, 0.72);
    font-weight: 600;
    font-size: 0.68rem;
    font-family: monospace;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  :global(.preview-identity) {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
  }

  :global(.preview-name) {
    margin: 0;
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  :global(.preview-tagline) {
    margin: 0.35rem 0 0;
    color: rgba(253, 245, 227, 0.86);
    font-size: 0.9rem;
    line-height: 1.45;
  }

  :global(.media-quadrant) {
    display: flex;
    flex-direction: column;
  }

  :global(.media-frame) {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.25);
    aspect-ratio: 16 / 9;
    width: 100%;
    max-height: 480px;
    overflow: hidden;
  }

  :global(.media-article) {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    background:
      radial-gradient(circle at 10% 14%, color-mix(in srgb, var(--media-accent, #5fb3a1) 22%, transparent) 0%, transparent 45%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(0, 0, 0, 0.16)),
      rgba(0, 0, 0, 0.28);
    padding: 1rem;
    color: inherit;
    text-decoration: none;

    &:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 28px color-mix(in srgb, var(--media-accent, #5fb3a1) 18%, transparent);
      border-color: color-mix(in srgb, var(--media-accent, #5fb3a1) 55%, rgba(255, 255, 255, 0.14));
    }

    &:focus-visible {
      outline: 2px solid var(--vibeset-valence);
      outline-offset: 2px;
    }
  }

  :global(.media-article-glow) {
    position: absolute;
    opacity: 0.55;
    inset: auto -12% -18% auto;
    width: 180px;
    height: 180px;
    background: radial-gradient(circle, color-mix(in srgb, var(--media-accent, #5fb3a1) 28%, transparent) 0%, transparent 70%);
    pointer-events: none;
  }

  :global(.media-article-copy) {
    display: flex;
    position: relative;
    z-index: 1;
    flex-direction: column;
    gap: 0.65rem;
  }

  :global(.media-article-copy h3) {
    margin: 0;
    max-width: 18ch;
    color: var(--media-accent, #5fb3a1);
    font-size: clamp(1.05rem, 1.4vw, 1.3rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  :global(.media-article-copy p) {
    margin: 0;
    max-width: 38ch;
    color: rgba(253, 245, 227, 0.8);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  :global(.media-article-cta) {
    display: inline-flex;
    position: relative;
    z-index: 1;
    align-items: center;
    gap: 0.35rem;
    align-self: flex-start;
    color: rgba(253, 245, 227, 0.96);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  :global(.media-article-cta-icon) {
    color: var(--media-accent, #5fb3a1);
    font-size: 0.9rem;
  }

  :global(.media-video) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.media-placeholder) {
    display: flex;
    position: relative;
    flex: 1;
    flex-direction: column;
    justify-content: center;
    gap: 0.45rem;
    border: 1px dashed color-mix(in srgb, var(--media-accent, #5fb3a1) 48%, rgba(255, 255, 255, 0.2));
    border-radius: 10px;
    background:
      radial-gradient(
        circle at 12% 12%,
        color-mix(in srgb, var(--media-accent, #5fb3a1) 30%, transparent) 0%,
        transparent 55%
      ),
      rgba(0, 0, 0, 0.2);
    padding: 0.9rem;
    min-height: 170px;
  }

  :global(.media-placeholder h3) {
    margin: 0;
    color: var(--media-accent, #5fb3a1);
    font-size: 1rem;
  }

  :global(.media-placeholder p) {
    margin: 0;
    color: rgba(253, 245, 227, 0.78);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  :global(.media-placeholder-badge) {
    align-self: flex-start;
    border: 1px solid color-mix(in srgb, var(--media-accent, #5fb3a1) 58%, rgba(255, 255, 255, 0.3));
    border-radius: 999px;
    background: color-mix(in srgb, var(--media-accent, #5fb3a1) 18%, transparent);
    padding: 0.2rem 0.52rem;
    color: rgba(253, 245, 227, 0.92);
    font-size: 0.68rem;
    font-family: monospace;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  :global(.includes-buttons) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  :global(.includes-button) {
    display: inline-flex;
    align-items: center;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.38rem 0.7rem;
    color: rgba(253, 245, 227, 0.95);
    font-weight: 500;
    font-size: 0.79rem;
    line-height: 1.2;
    text-decoration: none;
    white-space: nowrap;

    &:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 12px color-mix(in srgb, var(--product-accent, rgba(95, 179, 161, 0.45)) 25%, transparent);
      border-color: var(--product-accent, rgba(95, 179, 161, 0.45));
      background: color-mix(in srgb, var(--product-accent, rgba(95, 179, 161, 0.16)) 16%, transparent);
      color: #fff;
    }

    &:focus-visible {
      outline: 2px solid var(--vibeset-valence);
      outline-offset: 2px;
    }
  }

  :global(.features-list) {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  :global(.feature-chip) {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.03);
    padding: 0.55rem 0.7rem;
    color: rgba(253, 245, 227, 0.94);
    font-size: 0.84rem;
  }

  :global(.feature-bar) {
    flex-shrink: 0;
    border-radius: 10px;
    width: 3px;
    height: 18px;
  }

  :global(.console-grid) {
    /* Deprecated in new layout but kept for safety if used elsewhere */
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 1.5rem;
    margin-top: 0.25rem;
  }

  :global(.console-studio-name) {
    margin: 0;
    background: linear-gradient(135deg, var(--product-accent, #fff), #fff 80%);
    -webkit-background-clip: text;
    background-clip: text;
    font-weight: 700;
    font-size: 2rem;
    letter-spacing: -0.02em;
    -webkit-text-fill-color: transparent;
  }

  :global(.console-tagline) {
    display: block;
    margin-top: 0.3rem;
    color: var(--vibeset-valence);
    font-weight: 500;
    font-size: 0.96rem;
  }

  :global(.console-description) {
    margin: 1rem 0 0;
    color: rgba(253, 245, 227, 0.86);
    font-size: 1rem;
    line-height: 1.65;
  }

  :global(.tech-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  :global(.tech-tag) {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.28rem 0.62rem;
    color: rgba(253, 245, 227, 0.78);
    font-size: 0.74rem;
    font-family: monospace;
  }

  @media (max-width: 1279px) {
    :global(.tab-bar-container) {
      padding: 0 2rem;
    }

    :global(.studio-tab-bar) {
      max-width: 100%;
    }

    :global(.console-content) {
      padding: 1.5rem 2rem 1.75rem;
    }

    :global(.apple-feature-layout) {
      grid-template-columns: 1fr;
    }

    :global(.feature-col-left) {
      order: 2; /* Put text below media on mid-size screens */
    }

    :global(.feature-col-right) {
      order: 1; /* Media primary */
    }

    :global(.console-header-row) {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1023px) {
    .switchboard-wrapper {
      padding: 1.5rem 0.75rem;
      min-height: auto;
    }

    .glass-container {
      min-height: auto;
      max-height: none;
      overflow: visible;
    }

    :global(.switchboard-interface),
    :global(.console-display),
    :global(.console-content) {
      height: auto;
      overflow: visible;
    }

    /* Ensure screen-track-outer keeps its clip for slide animation on mobile */
    :global(.screen-track-outer) {
      overflow: hidden;
    }

    :global(.tab-bar-container) {
      padding: 0 1.5rem;
    }

    :global(.gallery-track) {
      padding-right: 1rem;
    }

    :global(.studio-poster) {
      flex-basis: 104px;
      width: 104px;
      height: 104px;
    }
  }

  @media (max-width: 767px) {
    :global(.switchboard-interface) {
      padding-top: 1rem;
    }

    :global(.mobile-scroll-hint) {
      display: flex;
