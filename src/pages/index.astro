---
export const prerender = true

import DefaultLayout from '@layouts/DefaultLayout.astro'
import Hero from '@components/Hero.astro'
import LiveSignals from '@components/LiveSignals.astro'
import VibesetSection from '@components/VibesetSection.astro'
import ResearchTimeline from '@components/ResearchTimeline.astro'
import RangeStrip from '@components/RangeStrip.astro'
import CloseSection from '@components/CloseSection.astro'
---

<DefaultLayout title="Bishal Upadhyaya - AI Systems Architect">
  <Hero />

  <LiveSignals />

  <VibesetSection />

  <ResearchTimeline />

  <RangeStrip />

  <CloseSection />
</DefaultLayout>

<style lang="scss">
  /* Section spacing */
  section {
    padding: var(--space-3xl) 0;
  }

  .section-header {
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .section-title {
    margin-bottom: var(--space-xs);
    color: var(--foreground-color);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    font-family: var(--font-heading);
  }

  .section-subtitle {
    color: var(--color-warm-gray);
    font-size: 1.125rem;
  }
</style>
