---
export const prerender = true

import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHero from '@components/PageHero.astro'
import PublicationCard from '@components/PublicationCard.astro'
import { getCollection } from 'astro:content'

const publications = (await getCollection('publications', ({ id }) => !id.startsWith('_'))).sort(
  (a, b) => b.data.year - a.data.year,
)
---

<DefaultLayout
  title="Research - Bishal Upadhyaya"
  description="Peer-reviewed publications across neuroscience, medical imaging, and efficient deep learning."
>
  <PageHero title="Research" subtitle="Neurons first, models second — the papers behind the products." />

  <section class="publications">
    <div class="container" data-reveal-stagger>
      {publications.map((pub) => <PublicationCard {...pub.data} data-reveal />)}
    </div>
  </section>
</DefaultLayout>

<style lang="scss">
  .publications {
    padding: var(--space-2xl) 0 var(--space-3xl);

    .container {
      display: grid;
      gap: var(--space-l);
      margin-inline: auto;
      padding-inline: var(--space-m);
      max-width: 900px;
    }
  }
</style>
