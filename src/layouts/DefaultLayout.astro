---
import '@fontsource-variable/bricolage-grotesque'
import '@fontsource/dm-mono/400.css'
import '@fontsource/dm-mono/500.css'
import '../styles/tailwind.css'
import '../assets/scss/index.scss'
import SiteMeta from '@components/SiteMeta.astro'
import Header from '@components/Header.astro'
import Footer from '@components/Footer.astro'
import LoadingScreen from '@components/LoadingScreen.astro'
import Atmosphere from '@components/Atmosphere.astro'
import { ClientRouter } from 'astro:transitions'

const {
  title = 'Bishal Upadhyaya — AI Systems Architect',
  description = 'AI systems, end-to-end: peer-reviewed research on one side, shipped products on the other. Co-owner of Vibeset — AI music tooling with live demos right on this page.',
  url = Astro.site,
  image = 'social-preview-image.png',
  author = 'Bishal Upadhyaya',
} = Astro.props
---

<html lang="en" dir="ltr" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />

    <!-- favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <SiteMeta title={title} description={description.substring(0, 160)} url={url} image={image} author={author} />

    <script>
      import '../scripts/reveal.ts'
    </script>

    <!-- Apollo.io website visitor tracker — identifies visiting companies
         (global) and people (U.S. only). is:inline keeps Astro from bundling
         the third-party snippet, so it runs verbatim as Apollo ships it. -->
    <script is:inline>
      function initApollo() {
        var n = Math.random().toString(36).substring(7),
          o = document.createElement('script')
        ;(o.src = 'https://assets.apollo.io/micro/website-tracker/tracker.iife.js?nocache=' + n),
          (o.async = !0),
          (o.defer = !0),
          (o.onload = function () {
            window.trackingFunctions.onLoad({ appId: '69bca29b8b1c61001d8bd4c8' })
          }),
          document.head.appendChild(o)
      }
      initApollo()
    </script>

    <!-- Enable Astro View Transitions for all browsers -->
    <ClientRouter />
  </head>
  <body>
    <LoadingScreen />
    <Atmosphere />
    <Header />
    <main id="main-content" transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <style lang="scss" is:global>
      @use '../assets/scss/base/mixins' as *;

      // sticky footer on low content pages
      html,
      body {
        height: 100%;
        scroll-behavior: smooth;
      }

      body {
        display: flex;
        flex-direction: column;
        overflow-x: clip;
        overflow-y: auto;

        main {
          flex: 1 0 auto;
        }

        footer {
          flex-shrink: 0;
        }
      }

      pre {
        border: 2px solid var(--link-color);
        border-radius: 0.35rem;
        padding: 1rem;
      }

      .card {
        a {
          @include text-decoration(transparent, var(--foreground-color), 4px, 2px);
        }
      }
    </style>
  </body>
</html>
